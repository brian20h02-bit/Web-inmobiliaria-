# ── Base de datos ─────────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL
# Producción: usar usuario con permisos mínimos necesarios
DATABASE_URL=postgresql://user:password@localhost:5432/inmobiliaria

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Mínimo 32 caracteres en producción. Generar con: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción, especificar el dominio exacto del frontend
# Ejemplo: https://www.miinmobiliaria.com
CORS_ORIGIN=http://localhost:5173

# ── Cloudinary (almacenamiento de imágenes) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Ventana de tiempo en ms (default: 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de peticiones por ventana por IP
RATE_LIMIT_MAX=100
