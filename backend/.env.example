# ── Base de datos ─────────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL
# Producción: usar usuario con permisos mínimos necesarios
DATABASE_URL=postgresql://user:password@localhost:5432/inmobiliaria

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Mínimo 32 caracteres en producción. Generar con: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción, especificar el dominio exacto del frontend
# Ejemplo: https://www.miinmobiliaria.com
CORS_ORIGIN=http://localhost:5173

# ── Cloudinary (almacenamiento de imágenes) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Ventana de tiempo en ms (default: 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de peticiones por ventana por IP
RATE_LIMIT_MAX=100

# ── Email (verificación de cuentas) ───────────────────────────────────────────
# SMTP para envío de emails (ejemplo: Gmail, Resend, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
# Nombre y email remitente
SMTP_FROM="Paola Castillo Inmobiliaria <tu-correo@gmail.com>"
# URL base del frontend (para los links de verificación)
FRONTEND_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Crear credencial OAuth 2.0 en: https://console.cloud.google.com/
# Tipo: Aplicación web  |  Authorized origins: http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
